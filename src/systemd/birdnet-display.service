[Unit]
Description=BirdNET-Pi Remix Display Daemon
After=mosquitto.service
Requires=mosquitto.service

[Service]
User=birdnet
Environment=PYTHONPATH=/opt/birdnet-remix/src
ExecStart=/opt/birdnet-remix/venv/bin/python3 /opt/birdnet-remix/src/display/daemon.py
Restart=on-failure
RestartSec=3s

[Install]
WantedBy=birdnet-remix.target
